"function _notebooklm_completion;\n    set -l response (env _NOTEBOOKLM_COMPLETE=fish_complete COMP_WORDS=(commandline -cp) COMP_CWORD=(commandline -t) notebooklm);\n\n    for completion in $response;\n        set -l metadata (string split \n $completion);\n\n        if test $metadata[1] = \"dir\";\n            __fish_complete_directories $metadata[2];\n        else if test $metadata[1] = \"file\";\n            __fish_complete_path $metadata[2];\n        else if test $metadata[1] = \"plain\";\n            if test $metadata[3] != \"_\";\n                echo $metadata[2]\t$metadata[3];\n            else;\n                echo $metadata[2];\n            end;\n        end;\n    end;\nend;\n\ncomplete --no-files --command notebooklm --arguments \"(_notebooklm_completion)\";\n"
